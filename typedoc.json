{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": [
        "src/index.ts",
        "src/html/index.ts",
        "src/http/index.ts",
        "src/forms/index.ts",
        "src/routing/index.ts",
        "src/i18n/index.ts",
        "src/elements/index.ts",
        "src/utils/index.ts",
        "src/di/index.ts",
        "src/collections/Index.ts"
    ],
    "json": "docs/api.json",
    "tsconfig": "tsconfig.json",
    "excludePrivate": true,
    "excludeInternal": true,
    "intentionallyNotExported": [
        "Validator",
        "WebComponentConstructor",
        "SortDirection",
        "ValidatorRegistryEntry",
        "Registration",
        "ErrorHandler",
        "RouteTargetHandler",
        "FetchFn",
        "BoundBinding",
        "ClickBinding",
        "Context",
        "FunctionsContext"
    ]
}
